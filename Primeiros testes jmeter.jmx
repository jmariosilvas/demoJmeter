        <hashTree>
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="manpulandoResponse" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">def response = prev.getResponseDataAsString()


log.info(&quot;ersponse completo: \n&quot;+response)</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223PostProcessor>
          <hashTree/>
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="manpulandodbResponse">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">

def falecido = vars.get(&quot;falecido_#&quot;) as int
log.info(&quot;\n ${falecido}&quot;)

if(falecido == 0) {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage(&quot;O registo pesquisado  nao esta falecido.&quot;)
    
}
def hasfalecido = vars.get(&quot;falecido_1&quot;)

log.info(&quot;Falecido: ${hasfalecido}&quot;)

if (hasfalecido == &quot;N&quot;) {
    prev.setSuccessful(true) 
    prev.setResponseMessage(&quot;TESTE PASSOU: o registro não está falecido&quot;)
} else {
    log.error(&quot;TESTE FALHOU: falecido = ${hasfalecido}&quot;)
    prev.setSuccessful(false) 
    prev.setResponseMessage(&quot;Falecido diferente de N: ${hasfalecido}&quot;)
}</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223PostProcessor>
