      <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="versao: ${versaoApp}">
        <stringProp name="scriptLanguage">groovy</stringProp>
        <stringProp name="parameters"></stringProp>
        <stringProp name="filename"></stringProp>
        <stringProp name="cacheKey">true</stringProp>
        <stringProp name="script">if (vars.get(&quot;versaoApp&quot;) == null &amp;&amp; sampler instanceof org.apache.jmeter.protocol.http.sampler.HTTPSamplerBase) {

    def url = &apos;https://devapp.seg-social.pt/eeaoc/fraw/version?dswid=3504&apos;
    def connection = new URL(url).openConnection()
    connection.setRequestMethod(&apos;GET&apos;)
    connection.connect()

    def html = connection.content.text

    def regex = /eeaoc-webapp:\s*([0-9A-Za-z.\-]+)/
    def matcher = (html =~ regex)
    if (matcher.find()) {
        def versao = matcher.group(1)
        vars.put(&quot;versaoApp&quot;, versao)
        log.info(&quot;Versão encontrada: &quot; + versao)
    } else {
        log.warn(&quot;Não foi possível encontrar a versão&quot;)
    }
}</stringProp>
      </JSR223PreProcessor>
      <hashTree/>
      <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="randomNumber" enabled="true">
        <stringProp name="scriptLanguage">groovy</stringProp>
        <stringProp name="parameters"></stringProp>
        <stringProp name="filename"></stringProp>
        <stringProp name="cacheKey">true</stringProp>
        <stringProp name="script">import org.apache.jmeter.protocol.http.sampler.HTTPSamplerProxy

def sampler = ctx.getCurrentSampler()

if (sampler instanceof HTTPSamplerProxy ) {
	def rand = new Random()
	def primeiro = rand.nextInt(9) + 1
	def resto = (1..10).collect { rand.nextInt(10) }
	def numero = ([primeiro] + resto).join(&quot;&quot;)
	vars.put(&quot;nissPSRandom&quot;, numero)

}</stringProp>
      </JSR223PreProcessor>
      <hashTree/>
      <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="catchLabelAcerto" enabled="false">
        <stringProp name="scriptLanguage">groovy</stringProp>
        <stringProp name="parameters"></stringProp>
        <stringProp name="filename"></stringProp>
        <stringProp name="cacheKey">true</stringProp>
        <stringProp name="script">import groovy.json.JsonSlurper

import org.apache.jmeter.protocol.http.sampler.HTTPSamplerProxy

def sampler = ctx.getCurrentSampler()

if (sampler instanceof HTTPSamplerProxy ) {
	def json = new JsonSlurper().parseText(sampler.getArguments().getArgument(0).getValue())
	def acerto = json.valores[0].acerto
	log.info(&quot;\nValor do campo &apos;acerto&apos; enviado: ${acerto}&quot;)
	vars.put(&quot;valorDoCampoAcerto&quot;, acerto)
    
}



</stringProp>
      </JSR223PreProcessor>
      <hashTree/>
      <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="catchLabelAcertov2" enabled="true">
        <stringProp name="scriptLanguage">groovy</stringProp>
        <stringProp name="parameters"></stringProp>
        <stringProp name="filename"></stringProp>
        <stringProp name="cacheKey">true</stringProp>
        <stringProp name="script">import groovy.json.JsonSlurper
import org.apache.jmeter.protocol.http.sampler.HTTPSamplerProxy

def sampler = ctx.getCurrentSampler()

if (sampler instanceof HTTPSamplerProxy) {

    def body = sampler.getArguments()?.getArgumentCount() &gt; 0 
        ? sampler.getArguments().getArgument(0).getValue() 
        : null

    if (!body) {
        log.info(&quot;Sem body (GET ou vazio)&quot;)
        vars.put(&quot;valorDoCampoAcerto&quot;, &quot;NAO_ENCONTRADO&quot;)
        return
    }

    try {
        def json = new JsonSlurper().parseText(body)
        def acerto = json?.valores?.getAt(0)?.acerto

        vars.put(&quot;valorDoCampoAcerto&quot;, acerto ?: &quot;NAO_ENCONTRADO&quot;)
        log.info(&quot;acerto: ${vars.get(&quot;valorDoCampoAcerto&quot;)}&quot;)

    } catch (Exception e) {
        log.info(&quot;JSON inválido&quot;)
        vars.put(&quot;valorDoCampoAcerto&quot;, &quot;ERRO_PARSE&quot;)
    }
}</stringProp>
      </JSR223PreProcessor>
