      <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="catchnaturezaRemuneracao" enabled="false">
        <stringProp name="scriptLanguage">groovy</stringProp>
        <stringProp name="parameters"></stringProp>
        <stringProp name="filename"></stringProp>
        <stringProp name="cacheKey">true</stringProp>
        <stringProp name="script">import groovy.json.JsonSlurper

import org.apache.jmeter.protocol.http.sampler.HTTPSamplerProxy

def sampler = ctx.getCurrentSampler()

if (sampler instanceof HTTPSamplerProxy ) {
	def json = new JsonSlurper().parseText(sampler.getArguments().getArgument(0).getValue())
	def naturezaRemuneracao = json.valores[0].naturezaRemuneracao
	vars.put(&quot;valorNaturezaRemuneracao&quot;, naturezaRemuneracao)
    
}
</stringProp>
      </JSR223PostProcessor>
      <hashTree/>
      <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="formmaterBD">
        <stringProp name="cacheKey">true</stringProp>
        <stringProp name="filename"></stringProp>
        <stringProp name="parameters"></stringProp>
        <stringProp name="script">def sampler = ctx.getCurrentSampler()

if (sampler instanceof org.apache.jmeter.protocol.jdbc.sampler.JDBCSampler) {
	def response = prev.getResponseDataAsString()
	def linhas = response.split(&quot;\n&quot;).collect { it.trim() }
	def tabela = linhas.collect { it.split(/\s+/) }
	def larguras = []
	
	for (cols in tabela) {
	    for (int i = 0; i &lt; cols.size(); i++) {
	        def col = cols[i]
	        if (i &gt;= larguras.size()) {
	            larguras &lt;&lt; col.size()
	        } else if (col.size() &gt; larguras[i]) {
	            larguras[i] = col.size()
	        }
	    }
	}
	def output = []
	for (cols in tabela) {
	    def linha = []
	    for (int i = 0; i &lt; cols.size(); i++) {
	        linha &lt;&lt; cols[i].padRight(larguras[i])
	    }
	    output &lt;&lt; linha.join(&quot;  &quot;)
	}
	
	log.info(&quot;Tabela:\n&quot; + output.join(&quot;\n&quot;))
}</stringProp>
        <stringProp name="scriptLanguage">groovy</stringProp>
      </JSR223PostProcessor>
