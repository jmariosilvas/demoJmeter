      <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="util_PostProcessor">
        <stringProp name="scriptLanguage">groovy</stringProp>
        <stringProp name="parameters"></stringProp>
        <stringProp name="filename"></stringProp>
        <stringProp name="cacheKey">true</stringProp>
        <stringProp name="script">import groovy.json.JsonSlurper


def expectField = { fieldName -&gt;
    def json = new JsonSlurper().parseText(prev.getResponseDataAsString())
    def value = json[fieldName]

    if (!value) {
        prev.setSuccessful(false)   
        prev.setResponseMessage(&quot;Campo &apos;${fieldName}&apos; não encontrado!&quot;)
        log.error(&quot;Campo &apos;${fieldName}&apos; não encontrado na resposta: ${prev.getResponseDataAsString()}&quot;)
    } else {
        vars.put(fieldName, value.toString()) 
        log.info(&quot;\n\nCampo &apos;${fieldName}&apos; extraído: ${value}&quot;)
    }
}


props.put(&quot;expectField&quot;, expectField)
log.info(&quot;\n/nFunção expectField carregada e disponível globalmente.&quot;)</stringProp>
        <stringProp name="TestPlan.comments">EEAOC-5.36.1-SNAPSHOT</stringProp>
      </JSR223PostProcessor>
      <hashTree/>
      <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="commonTeest">
        <stringProp name="scriptLanguage">groovy</stringProp>
        <stringProp name="parameters"></stringProp>
        <stringProp name="filename"></stringProp>
        <stringProp name="cacheKey">true</stringProp>
        <stringProp name="script">import org.apache.jmeter.protocol.http.sampler.HTTPSamplerProxy
import groovy.json.JsonSlurper

def sampler = ctx.getCurrentSampler()

if (sampler instanceof HTTPSamplerProxy &amp;&amp; prev?.getURL()) {
    def url = prev.getURL()
    vars.put(&quot;requestUrlSalvo&quot;, url.toString())
    if (url.getPath().toLowerCase().contains(&quot;v2&quot;)){ log.info(&quot;Testes sendo executados na v2&quot;)}


	def response = prev.getResponseDataAsString()
	if (!response) {
	    log.warn(&quot;Response vazio&quot;)
	    return
	}
	def json = new JsonSlurper().parseText(response)
	if (json?.comprovativoEntrega) {
	    vars.put(&quot;comprovativoEntrega&quot;, json.comprovativoEntrega.toString())
	    log.info(&quot;valor retornado: ${vars.get(&quot;comprovativoEntrega&quot;)}&quot;)
	} 
   
}

</stringProp>
      </JSR223PostProcessor>
