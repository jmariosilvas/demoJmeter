    &quot;comprovativo&quot;: &quot;${comprovativoEntrega}&quot;,&#xd;
    &quot;nissTrabalhador&quot;: ${nissTrabalhador},&#xd;
    &quot;${anoMesLabel}&quot;: &quot;${anoMes}&quot;,&#xd;
    &quot;qualificacao&quot;: &quot;${tipoQualificacao}&quot;,&#xd;
    &quot;natureza&quot;: &quot;${naturezaRemuneracao}&quot;&#xd;
}</stringProp>
                  <stringProp name="Argument.metadata">=</stringProp>
                </elementProp>
              </collectionProp>
