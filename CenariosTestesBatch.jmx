      <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="randomNumber" enabled="true">
        <stringProp name="scriptLanguage">groovy</stringProp>
        <stringProp name="parameters"></stringProp>
        <stringProp name="filename"></stringProp>
        <stringProp name="cacheKey">true</stringProp>
        <stringProp name="script">import org.apache.jmeter.protocol.http.sampler.HTTPSamplerProxy

def sampler = ctx.getCurrentSampler()

if (sampler instanceof HTTPSamplerProxy ) {
	def rand = new Random()
	def primeiro = rand.nextInt(9) + 1
	def resto = (1..10).collect { rand.nextInt(10) }
	def numero = ([primeiro] + resto).join(&quot;&quot;)
	vars.put(&quot;nissPSRandom&quot;, numero)

}</stringProp>
      </JSR223PreProcessor>
