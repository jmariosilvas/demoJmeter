      <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="interador" enabled="true">
        <stringProp name="scriptLanguage">groovy</stringProp>
        <stringProp name="parameters"></stringProp>
        <stringProp name="filename"></stringProp>
        <stringProp name="cacheKey">true</stringProp>
        <stringProp name="script">import groovy.json.JsonSlurper

import org.apache.jmeter.protocol.http.sampler.HTTPSamplerProxy

def sampler = ctx.getCurrentSampler()

if (sampler instanceof HTTPSamplerProxy ) {
	def count = vars.get(&quot;COUNTER&quot;) as Integer ?: 0
	count++
	vars.put(&quot;COUNTER&quot;, count.toString())
    
}
</stringProp>
