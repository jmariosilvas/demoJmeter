      <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="startGroovy">
        <stringProp name="cacheKey">true</stringProp>
        <stringProp name="filename"></stringProp>
        <stringProp name="parameters"></stringProp>
        <stringProp name="script">try {
    log.info(&quot;Teste de inicialização do Groovy&quot;)
} catch (Exception e) {
	//IOException reading the service definition at jar
    log.warn(&quot;Error detectado no Groovy. Pode ser problema com JAR ou drive de rede. Reiniciar o JMeter!&quot;)
}

log.info(&quot;Executando os testes!&quot;)

</stringProp>
        <stringProp name="scriptLanguage">groovy</stringProp>
      </JSR223PreProcessor>
      <hashTree/>
      <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="${versaoApp}">
        <stringProp name="scriptLanguage">groovy</stringProp>
        <stringProp name="parameters"></stringProp>
        <stringProp name="filename"></stringProp>
        <stringProp name="cacheKey">true</stringProp>
        <stringProp name="script">

    def url = &apos;https://devapp.seg-social.pt/eeaoc/fraw/version?dswid=3504&apos;
    def connection = new URL(url).openConnection()
    connection.setRequestMethod(&apos;GET&apos;)
    connection.connect()

    def html = connection.content.text

    def regex = /eeaoc-webapp:\s*([0-9A-Za-z.\-]+)/
    def matcher = (html =~ regex)
    if (matcher.find()) {
        def versao = matcher.group(1)
        vars.put(&quot;versaoApp&quot;, versao)
        log.info(&quot;Versão encontrada: &quot; + versao)
    } else {
        log.warn(&quot;Não foi possível encontrar a versão&quot;)
    }

</stringProp>
      </JSR223PreProcessor>
