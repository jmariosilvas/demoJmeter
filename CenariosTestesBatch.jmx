        <hashTree>
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="manpulandoResponse" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">def response = prev.getResponseDataAsString()

if(response.contains(&quot;Por omissao, &lt;ptss&gt;.&quot;)){
	log.info(&quot;Validar omissão, ptss [ok]&quot;)
	prev.setSuccessful(true)

}else{
	log.error(&quot;Validar de omissão não encontrado ptss&quot;)
	prev.setSuccessful(false)
	}


log.info(&quot;Valroes em PTEC ersponse completo: \n&quot;+response)</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223PostProcessor>
          <hashTree/>
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="formmater" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">def response = prev.getResponseDataAsString()

// separa as linhas
def linhas = response.split(&quot;\n&quot;).collect { it.trim() }

// separa as colunas (espaços múltiplos)
def tabela = linhas.collect { it.split(/\s+/) }

// calcula a largura de cada coluna
def larguras = []

for (cols in tabela) {
    for (int i = 0; i &lt; cols.size(); i++) {
        def col = cols[i]
        if (i &gt;= larguras.size()) {
            larguras &lt;&lt; col.size()
        } else if (col.size() &gt; larguras[i]) {
            larguras[i] = col.size()
        }
    }
}

// monta a tabela formatada
def output = []
for (cols in tabela) {
    def linha = []
    for (int i = 0; i &lt; cols.size(); i++) {
        linha &lt;&lt; cols[i].padRight(larguras[i])
    }
    output &lt;&lt; linha.join(&quot;  &quot;)
}

log.info(&quot;Tabela formatada:\n&quot; + output.join(&quot;\n&quot;))</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223PostProcessor>
          <hashTree/>
