      <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="versao: ${versaoApp}" enabled="true">
        <stringProp name="scriptLanguage">groovy</stringProp>
        <stringProp name="parameters"></stringProp>
        <stringProp name="filename"></stringProp>
        <stringProp name="cacheKey">true</stringProp>
        <stringProp name="script">
if(vars.get(&quot;versaoApp&quot;) == null){

	def url = &apos;https://devapp.seg-social.pt/eeaoc/fraw/version?dswid=3504&apos;
    def connection = new URL(url).openConnection()
    connection.setRequestMethod(&apos;GET&apos;)
    connection.connect()

    def html = connection.content.text

    def regex = /eeaoc-webapp:\s*([0-9A-Za-z.\-]+)/
    def matcher = (html =~ regex)
    if (matcher.find()) {
        def versao = matcher.group(1)
        vars.put(&quot;versaoApp&quot;, versao)
        log.info(&quot;Versão encontrada: &quot; + versao)
    } else {
        log.warn(&quot;Não foi possível encontrar a versão&quot;)
    }

}</stringProp>
      </JSR223PreProcessor>
