          <stringProp name="query">SELECT DISTINCT ee.NISS_EE AS NISS_EE, 
   vc.NISS_PS AS NISS_PS, 
   vc.ANO_MES AS ANOMES, 
   vc.NATUREZA_REMUNERACAO AS NATUREZA, 
   vc.TIPO_QLF AS TIPO_QLF 
