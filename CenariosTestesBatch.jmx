        <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="Query_Arr_BatchTVCD" enabled="true">
          <stringProp name="dataSource">dbConnection</stringProp>
          <stringProp name="query">SELECT
    ec.NISS_EE,
    vcd.NISS_PS,
    vcd.ANO_MES ,
    vcd.NATUREZA_REMUNERACAO,
    vcd.TIPO_QLF
FROM eeaoc.ENTIDADE_COMUNICADA ec
JOIN eeaoc.VALOR_COMUNICADO_DIFERENCA vcd
    ON ec.ID_ENTIDADE_COMUNICADA = vcd.ID_ENTIDADE_COMUNICADA
WHERE vcd.TEMA NOT IN (&apos;DESCONSIDERADO&apos;,&apos;PROCESSADO&apos;)
AND ec.NISS_EE = ${NISSEE}
AND vcd.NISS_PS = ${NISSPS}
--AND vcd.ANO_MES = ?
--AND vcd.TIPO_QLF = ?
--AND vcd.NATUREZA_REMUNERACAO = ?
GROUP BY
    ec.NISS_EE,
    vcd.NISS_PS,
    vcd.ANO_MES,
    vcd.NATUREZA_REMUNERACAO,
    vcd.TIPO_QLF</stringProp>
          <stringProp name="queryArguments"></stringProp>
          <stringProp name="queryArgumentsTypes"></stringProp>
          <stringProp name="queryTimeout"></stringProp>
          <stringProp name="queryType">Select Statement</stringProp>
          <stringProp name="resultSetHandler">Store as String</stringProp>
          <stringProp name="resultSetMaxRows"></stringProp>
          <stringProp name="resultVariable"></stringProp>
          <stringProp name="variableNames">NISS_EE</stringProp>
        </JDBCSampler>
        <hashTree>
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Validar  que a query de  arranque vai trazer dois registos" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">def hasCount = vars.get(&quot;NISS_EE_#&quot;)?.trim()?.toInteger()

log.info(&quot;\n\nQTT DE REGISTOS: ${hasCount}&quot;)

if(hasCount == 2){
	log.info(&quot;\n\nQTT DE REGISTOS OK: ${hasCount}&quot;)
}
else
{
    prev.setSuccessful(false) 
    prev.setResponseMessage(&quot;\n\nQuantidade de registos idferente da esperada: ${hasCount}&quot;)
	
}

</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223PostProcessor>
          <hashTree/>
        </hashTree>
        <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="ENTIDADE_CANDIDATO_PROCESSAMENTO" enabled="true">
          <stringProp name="dataSource">dbConnection</stringProp>
          <stringProp name="query">SELECT * FROM eeaoc.candidato_processamento where niss_ee=${niss_ee} and niss_ps=${niss_ps}</stringProp>
          <stringProp name="queryArguments"></stringProp>
          <stringProp name="queryArgumentsTypes"></stringProp>
          <stringProp name="queryTimeout"></stringProp>
          <stringProp name="queryType">Select Statement</stringProp>
          <stringProp name="resultSetHandler">Store as String</stringProp>
          <stringProp name="resultSetMaxRows"></stringProp>
          <stringProp name="resultVariable"></stringProp>
          <stringProp name="variableNames">ID_CANDIDATO_PROCESSAMENTO,  NISS_EE, NISS_PS, ANO_MES_INICIO,  ESTADO, DATA_ESTADO,  ANO_MES_FIM,  TIPO_QUALIFICACAO,  ADESAO_OFICIOSA</stringProp>
        </JDBCSampler>
        <hashTree>
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Validar  que a query trouxe dados" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">//def hasCount = vars.get(&quot;ESTADO_1&quot;)?.trim()?.toInteger()
def hasCount = vars.get(&quot;ESTADO_1&quot;)?.trim()?.toString()

log.info(&quot;\n\nQTT DE REGISTOS: ${hasCount}&quot;)

if(hasCount == &quot;INICIAL&quot;){
	log.info(&quot;O ESTADO É ${hasCount}&quot;)
}
else
{
    prev.setSuccessful(false) 
    prev.setResponseMessage(&quot;O ESTAD RETORNADO NÃO É O ESPERADO, RETORNADO: ${hasCount}&quot;)
	
}

</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223PostProcessor>
          <hashTree/>
        </hashTree>
        <GenericController guiclass="LogicControllerGui" testclass="GenericController" testname="Validar registo do processamento [RN0068]"/>
        <hashTree>
          <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="JOIN [valor_comunicado_diferenca e processamento_valor_dif]">
            <stringProp name="dataSource">dbConnection</stringProp>
            <stringProp name="query">SELECT v.*, p.*
FROM EEAOC.valor_comunicado_diferenca v
JOIN EEAOC.processamento_valor_dif p
    ON v.id_valor_comunicado_diferenca = p.id_valor_comunicado_diferenca</stringProp>
            <stringProp name="queryArguments"></stringProp>
            <stringProp name="queryArgumentsTypes"></stringProp>
            <stringProp name="queryTimeout"></stringProp>
            <stringProp name="queryType">Select Statement</stringProp>
            <stringProp name="resultSetHandler">Store as String</stringProp>
            <stringProp name="resultSetMaxRows"></stringProp>
            <stringProp name="resultVariable"></stringProp>
            <stringProp name="variableNames">QTTREGISTOS</stringProp>
          </JDBCSampler>
          <hashTree>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="validar que existe 1 registro" enabled="true">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">def hasCount = vars.get(&quot;QTTREGISTOS_#&quot;)?.trim()?.toInteger()

if(hasCount &gt;= 2)
{
	log.info(&quot;\nQTT DE REGISTOS: ${hasCount}&quot;)
}
else
{
    prev.setSuccessful(false) 
    prev.setResponseMessage(&quot;\nQuantidade de registos idferente da esperada: ${hasCount}&quot;)
    log.ERROR(&quot;\nQTT DE REGISTOS: ${hasCount} não corresponse a esperada, possivel Bug.&quot;)
	
}

</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223PostProcessor>
