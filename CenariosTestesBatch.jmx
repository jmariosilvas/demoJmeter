            <stringProp name="parameters"></stringProp>
            <stringProp name="script">def hasCount = vars.get(&quot;IDENTIFICADOR_ARGUMENTO_#&quot;)?.trim()?.toInteger()

log.info(&quot;\n\nQTT DE REGISTOS: ${hasCount}&quot;)

if(hasCount &gt;= 1){
