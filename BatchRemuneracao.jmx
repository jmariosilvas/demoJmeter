        <GenericController guiclass="LogicControllerGui" testclass="GenericController" testname="RS0020 - Inserir ou atualizar Vínculo Mensal" enabled="true">
          <stringProp name="TestPlan.comments">Quando no momento do processamento de um evento o sistema determina que ainda não existe um registo na entidade vínculo mensal para o período a processamento (entidade empregadora e ano-mês referencia) e trabalhador a processamento então é criado um novo registo com as seguintes informações:</stringProp>
        </GenericController>
        <hashTree>
          <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="entidade_empregadora + periodo_mensal " enabled="true">
            <stringProp name="dataSource">dbConnection</stringProp>
            <stringProp name="query">SELECT * FROM EEAOC.entidade_empregadora ee
LEFT JOIN EEAOC.periodo_mensal pm
on ee.id_entidade_empregadora = pm.id_entidade_empregadora
where ee.id_entidade_empregadora = 2222</stringProp>
            <stringProp name="queryArguments"></stringProp>
            <stringProp name="queryArgumentsTypes"></stringProp>
            <stringProp name="queryTimeout"></stringProp>
            <stringProp name="queryType">Select Statement</stringProp>
            <stringProp name="resultSetHandler">Store as String</stringProp>
            <stringProp name="resultSetMaxRows"></stringProp>
            <stringProp name="resultVariable"></stringProp>
            <stringProp name="variableNames">ID_TRABALHADOR</stringProp>
            <stringProp name="TestPlan.comments">Vínculo mensal é basicamente pelo que  entendi um registro que represent: A relação entre empresa (entidade empregadora) e trabalhador Para um mês específico (ano-mês de referência)</stringProp>
          </JDBCSampler>
          <hashTree>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="periodo_mensal " enabled="true">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">def hasCount = vars.get(&quot;ID_TRABALHADOR_#&quot;)?.trim()?.toInteger()


if(hasCount &gt;=1 ){
	log.info(&quot;\n\nQTT DE REGISTOS OK: ${hasCount}&quot;)
}
else
{
    prev.setSuccessful(false) 
    prev.setResponseMessage(&quot;[AVISO] NÃO TROUXE REGISTOS]: ${hasCount}&quot;)
	
}

</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223PostProcessor>
            <hashTree/>
          </hashTree>
        </hashTree>
