        <hashTree>
          <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="QUERY__RRAN" enabled="true">
            <stringProp name="dataSource">dbConnection</stringProp>
            <stringProp name="query">SELECT p.ID_PERIODO_MENSAL, r.ID_VINCULO_MENSAL, e.NISS_EE, t.NISS_PS, p.ANO_MES_REFERENCIA  
FROM EEAOC.VINCULO_MENSAL r  INNER JOIN EEAOC.PERIODO_MENSAL p ON p.ID_PERIODO_MENSAL = r.ID_PERIODO_MENSAL  
INNER JOIN EEAOC.ENTIDADE_EMPREGADORA e ON e.ID_ENTIDADE_EMPREGADORA =
 p.ID_ENTIDADE_EMPREGADORA  INNER JOIN EEAOC.TRABALHADOR t ON t.ID_TRABALHADOR = r.ID_TRABALHADOR 
 WHERE r.ESTADO = &apos;INICIAL&apos;  AND e.NISS_EE = ${nissEE} AND t.NISS_PS = ${nissPS} AND p.ANO_MES_REFERENCIA = &apos;${anoMes}&apos;</stringProp>
            <stringProp name="queryArguments"></stringProp>
            <stringProp name="queryArgumentsTypes"></stringProp>
            <stringProp name="queryTimeout"></stringProp>
            <stringProp name="queryType">Select Statement</stringProp>
            <stringProp name="resultSetHandler">Store as String</stringProp>
            <stringProp name="resultSetMaxRows"></stringProp>
            <stringProp name="resultVariable"></stringProp>
            <stringProp name="variableNames">ID_PERIODO_MENSAL, ID_VINCULO_MENSAL, NISS_EE, NISS_PS, ANO_MES_REFERENCIA</stringProp>
          </JDBCSampler>
          <hashTree>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="qtt_registos_na_query" enabled="true">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">def hasCount = vars.get(&quot;ID_PERIODO_MENSAL_#&quot;)?.trim()?.toInteger() ?: 0
def ok = (hasCount == 1)

prev.setSuccessful(ok)

def msg = ok 
    ? &quot;QTT DE REGISTROS OK: ${hasCount}&quot; 
    : &quot;[AVISO] NÃO TROUXE REGISTROS: ${hasCount}&quot;

prev.setResponseMessage(msg)
(ok ? log.info(msg) : log.error(msg))
</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223PostProcessor>
