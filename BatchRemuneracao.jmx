        <GenericController guiclass="LogicControllerGui" testclass="GenericController" testname="605: Validar processamento, quando estado diferente de INICIAL na entidade periodo_mensal" enabled="true"/>
        <hashTree>
          <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="NISS_ANOMES" enabled="true">
            <stringProp name="dataSource">dbConnection</stringProp>
            <stringProp name="query">select pm.id_periodo_mensal, pm.id_entidade_empregadora, pm.ano_mes_referencia,pm.estado,
ee.niss_ee,t.niss_ps, ee.estado_atualizacao_candidato, 
vm.id_vinculo_mensal,   vm.id_trabalhador, t.ID_TRABALHADOR
from eeaoc.periodo_mensal pm
join EEAOC.entidade_empregadora ee
on pm.id_entidade_empregadora = ee.id_entidade_empregadora
join eeaoc.vinculo_mensal vm
on vm.id_periodo_mensal =pm.id_periodo_mensal
left join eeaoc.trabalhador t
on vm.id_trabalhador =  t.id_trabalhador
where pm.estado = &apos;INICIAL&apos;
  and vm.estado = &apos;INICIAL&apos;
  and ee.estado_atualizacao_candidato not in (&apos;CALCULADA_REMUNERACAO&apos;)
  FETCH FIRST 3 ROWS ONLY</stringProp>
            <stringProp name="queryArguments"></stringProp>
            <stringProp name="queryArgumentsTypes"></stringProp>
            <stringProp name="queryTimeout"></stringProp>
            <stringProp name="queryType">Select Statement</stringProp>
            <stringProp name="resultSetHandler">Store as String</stringProp>
            <stringProp name="resultSetMaxRows"></stringProp>
            <stringProp name="resultVariable"></stringProp>
            <stringProp name="variableNames">ID_PERIODO_MENSAL, ID_ENTIDADE_EMPREGADORA, ANO_MES_REFERENCIA, ESTADO, NISS_EE, NISS_PS, ESTADO_ATUALIZACAO_CANDIDATO, ID_VINCULO_MENSAL, ID_TRABALHADOR</stringProp>
          </JDBCSampler>
          <hashTree>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="VERIFICAR_SE_TEM_NISS_EE_NISS_PS">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">def hasCount = vars.get(&quot;NISS_EE_#&quot;)?.trim()?.toInteger() ?: 0
def ok = (hasCount &gt;= 1)

prev.setSuccessful(ok)

def msg = ok 
    ? &quot;EXECUTE O BATCH COM OS  NISS_EE : ${NISS_EE_1}, NISS_PS:${NISS_PS_1}, ANOMES: ${ANO_MES_REFERENCIA_1}&quot; 
    : &quot;[AVISO] NÃO TROUXE REGISTROS NISS_EE: ${hasCount}&quot;

prev.setResponseMessage(msg)
(ok ? log.info(msg) : log.error(msg))


</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223PostProcessor>
            <hashTree/>
          </hashTree>
          <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="VALIDAR QUANTIDADE DE CAND">
            <stringProp name="dataSource">dbConnection</stringProp>
            <stringProp name="query">SELECT p.ID_PERIODO_MENSAL, r.ID_VINCULO_MENSAL, e.NISS_EE, t.NISS_PS, p.ANO_MES_REFERENCIA 
FROM EEAOC.VINCULO_MENSAL r  
INNER JOIN EEAOC.PERIODO_MENSAL p ON p.ID_PERIODO_MENSAL = r.ID_PERIODO_MENSAL 
INNER JOIN EEAOC.ENTIDADE_EMPREGADORA e ON e.ID_ENTIDADE_EMPREGADORA = p.ID_ENTIDADE_EMPREGADORA
INNER JOIN EEAOC.TRABALHADOR t ON t.ID_TRABALHADOR = r.ID_TRABALHADOR  
WHERE r.ESTADO = &apos;INICIAL&apos;  AND e.NISS_EE = &apos;${NISS_EE_1}&apos; AND t.NISS_PS= &apos;${NISS_PS_1}&apos; AND p.ANO_MES_REFERENCIA = &apos;${ANO_MES_REFERENCIA_1}&apos;</stringProp>
            <stringProp name="queryArguments"></stringProp>
            <stringProp name="queryArgumentsTypes"></stringProp>
            <stringProp name="queryTimeout"></stringProp>
            <stringProp name="queryType">Select Statement</stringProp>
            <stringProp name="resultSetHandler">Store as String</stringProp>
            <stringProp name="resultSetMaxRows"></stringProp>
            <stringProp name="resultVariable"></stringProp>
            <stringProp name="variableNames">VALOR</stringProp>
          </JDBCSampler>
          <hashTree>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="VERIFICAR_SE_TEM_NISS_EE_NISS_PS">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">def hasCount = vars.get(&quot;VALOR_#&quot;)?.trim()?.toInteger() ?: 0
def ok = (hasCount &gt;= 1)

prev.setSuccessful(ok)

def msg = ok 
    ? &quot;QUANTIDADE DE CANDITADOS: ${NISS_EE_1}&quot; 
    : &quot;[AVISO] NÃO TROUXE REGISTROS: ${hasCount}&quot;

prev.setResponseMessage(msg)
(ok ? log.info(msg) : log.error(msg))


</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223PostProcessor>
            <hashTree/>
          </hashTree>
        </hashTree>
        <WhileController guiclass="WhileControllerGui" testclass="WhileController" testname="vERIFICANDO SE O BATCH FOI EXECUTADO">
          <stringProp name="WhileController.condition">${__groovy(vars.get(&quot;READY&quot;) != &quot;1&quot;)}</stringProp>
        </WhileController>
        <hashTree>
          <JDBCSampler guiclass="TestBeanGUI" testclass="JDBCSampler" testname="FRAB">
            <stringProp name="dataSource">ptecConnection</stringProp>
            <stringProp name="query">
SELECT 
  e.IDENTIFICADOR_EXECUCAO, 
  i.VERSAO_SUBSISTEMA, 
  B.Identificador_Batch, 
  TO_CHAR(e.DATA_INICIO,&apos;yyyy/mm/dd hh24:MI:ss&apos;) AS data_inicio, 
  TO_CHAR(e.DATA_FIM,&apos;yyyy/mm/dd hh24:MI:ss&apos;)    AS data_fim, 
  (NVL(e.DATA_FIM,SYSDATE)-e.DATA_INICIO) DURACAO, 
  e.UNIDADES_CANDIDATAS AS UN_CAND, 
  e.UNIDADES_IGNORADAS AS UN_IGN, 
  e.UNIDADES_PROCESSADAS AS UN_PROC, 
  e.ERROS, 
  ae.NOME AS PARAMETRO,  
  ae.VALOR_SIMPLES, 
  EE.DESIGNACAO ESTADO, 
  e.PILHA_ERRO_RAZAO, 
  e.CONTROLO_CONCORRENCIA, 
  erro.classe_erro, 
  erro.mensagem_erro, 
  COALESCE(
    REGEXP_SUBSTR(erro.pilha_erro, &apos;ORA-[0-10]+:.*&apos;),
    REGEXP_SUBSTR(erro.pilha_erro, &apos;^[^\\n]+&apos;)
  ) AS pilha_erro
FROM FRAB.SERVIDOR_FRAB s 
INNER JOIN FRAB.INSTALACAO_BATCH i 
    ON i.SERVIDOR = s.IDENTIFICACAO_SERVIDOR 
INNER JOIN FRAB.BATCH_FRAB b 
    ON b.IDENTIFICACAO_SEQUENCIAL = i.BATCH 
INNER JOIN FRAB.execucao_frab e 
    ON e.INSTALACAO_BATCH = i.IDENTIFICACAO_SEQUENCIAL 
INNER JOIN FRAB.estado_execucao ee 
    ON ee.CODIGO_ESTADO_EXECUCAO = e.ESTADO 
INNER JOIN FRAB.ARGUMENTO_EXECUCAO ae 
    ON ae.IDENTIFICADOR_EXECUCAO = e.IDENTIFICADOR_EXECUCAO 
LEFT JOIN FRAB.ERRO_FRAB erro 
    ON ae.IDENTIFICADOR_EXECUCAO = erro.IDENTIFICADOR_EXECUCAO 
WHERE i.Versao_Subsistema LIKE  &apos;EEAOC-${versaoApp}&apos;  
ORDER BY e.DATA_INICIO DESC
FETCH FIRST 4 ROWS ONLY</stringProp>
            <stringProp name="queryArguments"></stringProp>
            <stringProp name="queryArgumentsTypes"></stringProp>
            <stringProp name="queryTimeout"></stringProp>
            <stringProp name="queryType">Select Statement</stringProp>
            <stringProp name="resultSetHandler">Store as String</stringProp>
            <stringProp name="resultSetMaxRows"></stringProp>
            <stringProp name="resultVariable"></stringProp>
            <stringProp name="variableNames">IDENTIFICADOR_EXECUCAO, VERSAO_SUBSISTEMA, IDENTIFICADOR_BATCH, DATA_INICIO, DATA_FIM, DURACAO, UN_CAND, UN_IGN, UN_PROC, ERROS, PARAMETRO, VALOR_SIMPLES, ESTADO, PILHA_ERRO_RAZAO, CONTROLO_CONCORRENCIA, CLASSE_ERRO, MENSAGEM_ERRO, PILHA_ERRO</stringProp>
          </JDBCSampler>
          <hashTree>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="VERIFICAR_SE_TEM_NISS_EE_NISS_PS">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">def valor1 = vars.get(&quot;IDENTIFICADOR_BATCH_4&quot;)?.trim()
def valor2 = vars.get(&quot;VALOR_SIMPLES_4&quot;)?.trim()

log.info(&quot;BATCH: ${valor1}, VALOR: ${valor2}&quot;)

if (valor1 == &quot;RemuneracaoTrabalhadorMensal&quot; &amp;&amp; valor2 == &quot;20004325023&quot;) {
    log.warn(&quot;Batch RemuneracaoTrabalhadorMensal execuutado com o IDENTIFICADOR_EXECUCAO: ${vars.get(&quot;IDENTIFICADOR_EXECUCAO_4&quot;)}  &quot;)
    vars.put(&quot;READY&quot;, &quot;1&quot;)
} else {
    vars.put(&quot;READY&quot;, &quot;0&quot;)
}</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223PostProcessor>
            <hashTree/>
            <ConstantTimer guiclass="ConstantTimerGui" testclass="ConstantTimer" testname="Constant Timer">
              <stringProp name="ConstantTimer.delay">1000</stringProp>
            </ConstantTimer>
            <hashTree/>
          </hashTree>
        </hashTree>
      </hashTree>
    </hashTree>
  </hashTree>
</jmeterTestPlan>
